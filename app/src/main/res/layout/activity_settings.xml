<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_page">

    <!-- ════════ 渐变顶栏 ════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="@drawable/header_bg"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="16dp"
        android:elevation="6dp">

        <!-- 图标区 -->
        <LinearLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:gravity="center"
            android:background="@drawable/ic_bg_round"
            android:layout_marginEnd="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🎭"
                android:textSize="22sp" />
        </LinearLayout>

        <!-- 标题区 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="设备伪装"
                android:textColor="@color/on_primary"
                android:textSize="20sp"
                android:textStyle="bold"
                android:letterSpacing="0.02" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="自定义机型信息 · LSPosed 勾选即生效"
                android:textColor="@color/header_subtitle"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- 版本号 -->
        <TextView
            android:id="@+id/tv_version"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v2.2"
            android:textColor="@color/header_version_text"
            android:textSize="11sp"
            android:background="@color/header_version_bg"
            android:paddingHorizontal="8dp"
            android:paddingVertical="3dp" />
    </LinearLayout>

    <!-- ════════ 滚动内容 ════════ -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp"
        android:clipToPadding="false"
        android:scrollbarStyle="outsideOverlay">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ════════ 预设机型卡片 ════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="18dp"
                android:layout_marginBottom="20dp">

                <!-- 卡片头部 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📱"
                        android:textSize="22sp"
                        android:layout_marginEnd="10dp" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="预设机型"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <!-- 当前选中机型标签 -->
                    <TextView
                        android:id="@+id/tv_preset_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="一加 Ace 6T"
                        android:textColor="@color/on_primary_container"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:background="@color/primary_container"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="4dp" />
                </LinearLayout>

                <!-- 分割线 -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@drawable/divider_horizontal"
                    android:layout_marginTop="14dp"
                    android:layout_marginBottom="14dp" />

                <!-- 机型详情 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tv_preset_brand"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="OnePlus"
                            android:textColor="@color/text_primary"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_preset_model"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ACE6T"
                            android:textColor="@color/text_secondary"
                            android:textSize="14sp"
                            android:layout_marginTop="3dp" />

                        <TextView
                            android:id="@+id/tv_preset_android"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Android 15"
                            android:textColor="@color/text_tertiary"
                            android:textSize="12sp"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <!-- 选择按钮 -->
                    <TextView
                        android:id="@+id/btn_preset"
                        android:layout_width="120dp"
                        android:layout_height="38dp"
                        android:background="@drawable/btn_preset_bg"
                        android:text="切换机型"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:gravity="center"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>
            </LinearLayout>

            <!-- ════════ 属性配置区标题 ════════ -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp"
                android:paddingStart="4dp">

                <View
                    android:layout_width="4dp"
                    android:layout_height="18dp"
                    android:background="@color/primary"
                    android:layout_marginEnd="10dp" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="属性配置"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_enabled_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0/10"
                    android:textColor="@color/text_tertiary"
                    android:textSize="13sp" />
            </LinearLayout>

            <!-- ════════ 属性卡片容器（Java 动态构建） ════════ -->
            <LinearLayout
                android:id="@+id/card_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="8dp" />

            <!-- 长按编辑提示 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💡 长按属性值可自定义修改"
                android:textColor="@color/text_tertiary"
                android:textSize="12sp"
                android:gravity="center"
                android:layout_marginBottom="8dp"
                android:alpha="0.7" />

            <!-- 底部留白 -->
            <View
                android:layout_width="match_parent"
                android:layout_height="16dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
